{
  "name": "metaethics-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ios": "DEV_IP=$(ipconfig getifaddr en0) LIVE_RELOAD=1 npx cap copy ios && NEXT_PUBLIC_API_BASE=http://$(ipconfig getifaddr en0):8000 next dev --hostname 0.0.0.0",
    "build": "next build",
    "build:local": "NEXT_PUBLIC_API_BASE=http://$(ipconfig getifaddr en0):8000 next build",
    "start": "next start",
    "quick": "next build && npx cap copy ios",
    "quick:local": "NEXT_PUBLIC_API_BASE=http://$(ipconfig getifaddr en0):8000 next build && npx cap copy ios",
    "ios:sync": "PATH=\"/opt/homebrew/bin:$PATH\" npx cap sync ios",
    "ios:run": "PATH=\"/opt/homebrew/bin:$PATH\" npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/browser": "^7.0.4",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "next": "16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@types/node": "20.14.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "sass": "1.77.6",
    "typescript": "5.4.5"
  }
}
